{
  "name": "open-cc",
  "version": "0.1.0",
  "description": "An open-source terminal AI coding assistant",
  "type": "module",
  "main": "dist/entrypoints/cli.js",
  "bin": {
    "open-cc": "dist/entrypoints/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "postbuild": "chmod +x dist/entrypoints/cli.js",
    "dev": "tsx src/entrypoints/cli.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
