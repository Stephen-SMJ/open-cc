    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "ink": "^5.2.0",
    "ink-spinner": "^5.0.0",
    "ink-text-input": "^5.0.0",
    "openai": "^4.93.0",
    "react": "^18.3.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^18.3.20",
    "@vitest/coverage-v8": "^3.1.1",
    "ink-testing-library": "^4.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.1.1"
  }
